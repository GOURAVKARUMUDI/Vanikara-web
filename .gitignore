# ============================================================
# VANIKARA — .gitignore
# Comprehensive exclusion list for Next.js + TypeScript project
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js build output ────────────────────────────────────
/.next/
/out/
/build
.next/cache

# ─── Runtime / cache files ───────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cache/
.turbo/

# ─── Environment / secrets ───────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
*.pem
*.key
*.cert

# ─── Testing ─────────────────────────────────────────────────
/coverage
/playwright-report/
/test-results/
/playwright/.cache/

# ─── Production archives / data ──────────────────────────────
/build
db.json
data/*.runtime.json

# ─── OS / system files ───────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── IDEs and editors ────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swn
.history/
*.code-workspace

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Vercel / deployment ─────────────────────────────────────
.vercel
.netlify/

# ─── Misc output / uploads ───────────────────────────────────
/uploads/
/tmp/
*.zip
*.tar.gz

# ─── Sensitive config snapshots ──────────────────────────────
# Runtime privacy config cache (written under .next at runtime)
.next/privacy_config.json

# ─── Android signing secrets ──────────────────────────────────
android/app/vanikara-release.jks
android/key.properties

# ─── Native builds ───────────────────────────────────────────
*.apk
*.aab
